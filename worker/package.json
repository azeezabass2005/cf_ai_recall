{
  "name": "ranti-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Ranti agent backend — TypeScript on Cloudflare Workers (Agents SDK).",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply ranti-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ranti-db --remote",
    "test": "vitest run"
  },
  "dependencies": {
    "agents": "^0.0.50",
    "hono": "^4.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.81.0"
  }
}
