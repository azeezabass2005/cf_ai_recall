<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Ranti" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Edge-to-edge: transparent system bars so they blend with the app background -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- Ensure nav bar button icons adapt to app background -->
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
