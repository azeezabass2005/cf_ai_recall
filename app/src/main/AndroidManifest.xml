<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Permissions exercised in later milestones (§4 onwards) — declared early
         so the manifest matches SPEC §17.2 from day one. Runtime requests
         happen in the onboarding screens. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- API 33+ fast-path for reminder apps: auto-granted, no user opt-in.
         On API 31/32 we fall back to SCHEDULE_EXACT_ALARM + a settings intent. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".RecallApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:label="Recall"
        android:supportsRtl="true"
        android:theme="@style/Theme.Recall">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Recall">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>



        <!-- Active location monitor for reliable geofence triggering. -->
        <service
            android:name=".location.GeofenceMonitorService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Restart geofence monitoring after reboot if needed. -->
        <receiver
            android:name=".service.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- SPEC §7.3 — fires when a scheduled reminder alarm goes off. -->
        <receiver
            android:name=".reminders.ReminderReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.recall.action.FIRE_REMINDER" />
            </intent-filter>
        </receiver>

        <!-- SPEC §9 — geofence transitions for location-based reminders. -->
        <receiver
            android:name=".location.GeofenceBroadcastReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.location.Geofence" />
            </intent-filter>
        </receiver>

        <!-- SPEC §12.2 — handles Done / Snooze notification actions. -->
        <receiver
            android:name=".reminders.ReminderActionReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.recall.action.REMINDER_DONE" />
                <action android:name="com.recall.action.REMINDER_SNOOZE" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
